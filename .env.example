# Admin portal credentials
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=your-strong-password-here

# Default users — available on all browsers, no admin setup needed
# Use individual vars (recommended — avoids Vercel JSON corruption):
# Format: VITE_USER_1=email|password|name|role
VITE_USER_1=user@example.com|mypassword123|Jane Smith|team
VITE_USER_2=another@example.com|theirpass456|Bob Jones|team
# Or JSON array (may break on Vercel with long values):
# VITE_USERS=[{"email":"x","password":"y","name":"z","role":"team"}]
