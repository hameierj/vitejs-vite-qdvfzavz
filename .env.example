# Admin portal credentials
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=your-strong-password-here

# Default users (JSON array — available on all browsers, no admin setup needed)
# Format: [{"email":"user@example.com","password":"pass123","name":"Jane Smith","role":"team"}]
# role: "team" (full access) or "client" (read-only)
VITE_USERS=[]
